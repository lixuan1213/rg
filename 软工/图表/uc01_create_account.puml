@startuml
skinparam defaultFontName "Microsoft YaHei"
title createNewAccount(car_Id, userName, car_Capacity) 交互图

actor "车主" as User
participant "AccountController" as AC
participant "AccountService" as AS
database "CarAccountRepository" as CAR
database "H2 DB" as DB

User -> AC: POST /api/account/create\ncreateNewAccount(car_Id, userName, car_Capacity)
activate AC
AC -> AS: createNewAccount(request)
activate AS
AS -> CAR: existsById(car_Id)
activate CAR
CAR -> DB: SELECT COUNT(*) FROM car_account WHERE car_id=?
DB --> CAR: count
deactivate CAR
AS -> AS: 若已存在返回false
alt 账号不存在
    AS -> CAR: save(CarAccount)
    activate CAR
    CAR -> DB: INSERT INTO car_account(car_id, userName, car_Capacity)
    DB --> CAR: OK
    deactivate CAR
    AS --> AC: true
else 账号已存在
    AS --> AC: false
end
deactivate AS
AC --> User: Return(0/1)
deactivate AC

@enduml
